FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --legacy-peer-deps

# Copy source
COPY . .

# Set environment
ENV NEXT_PUBLIC_API_URL=https://riffai-backend-715107904640.asia-southeast1.run.app
ENV NODE_ENV=production

# Build
RUN npm run build

# Expose port
EXPOSE 3000

# Start
CMD ["npm", "start"]
